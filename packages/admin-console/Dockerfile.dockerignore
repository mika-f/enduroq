# Per-build ignore for the admin console image. BuildKit uses this file
# instead of the root .dockerignore, so the common ignores are repeated here.
**/.git
**/.gitignore
**/node_modules
**/dist
**/.next
**/.turbo
**/coverage
**/*.tsbuildinfo
**/.DS_Store
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Only the admin console belongs in this image.
packages/ts-server
packages/ts-worker
packages/ts-worker-example
packages/sql-schema
